{
  "uid": "rag-overview",
  "title": "RAG Pipeline Overview",
  "tags": ["aktilot", "rag"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "LLM Response Latency (avg ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 14, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "End-to-end LLM call latency per purpose. generate_answer is the dominant component of user-perceived latency.",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_llm_request_latency_ms_sum{rag_llm_purpose=\"generate\"}) / clamp_min(sum(rag_llm_request_latency_ms_count{rag_llm_purpose=\"generate\"}), 1)",
          "legendFormat": "generate_answer",
          "refId": "A",
          "range": true,
          "instant": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_llm_request_latency_ms_sum{rag_llm_purpose=\"keyword_extract\"}) / clamp_min(sum(rag_llm_request_latency_ms_count{rag_llm_purpose=\"keyword_extract\"}), 1)",
          "legendFormat": "extract_keywords",
          "refId": "B",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Chats",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_requests_chat_total)",
          "legendFormat": "total chats",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "title": "LLM Success Rate",
      "type": "stat",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.99 }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_llm_requests_total{finish_reason=\"stop\"}) / clamp_min(sum(rag_llm_requests_total), 1)",
          "legendFormat": "success rate",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Retrieval Top-1 Score",
      "type": "stat",
      "gridPos": { "x": 14, "y": 4, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Quality of the best chunk found. Below 0.4 = retrieval is not finding relevant content.",
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.4 }, { "color": "green", "value": 0.6 }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_reranker_score_top1_sum) / clamp_min(sum(rag_reranker_score_top1_count), 1)",
          "legendFormat": "avg top-1 score",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 5,
      "title": "Docs Returned / Requested",
      "type": "stat",
      "gridPos": { "x": 19, "y": 4, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Ratio of chunks returned vs requested. Below 1.0 = collection too sparse for the query.",
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.95 }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_retrieval_top_k_returned_sum) / clamp_min(sum(rag_retrieval_top_k_requested_sum), 1)",
          "legendFormat": "returned/requested",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 6,
      "title": "Activity Latency Breakdown (avg ms)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Where time is spent per chat request. Identifies the bottleneck activity.",
      "options": { "xTickLabelRotation": -15 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_llm_request_latency_ms_sum{rag_llm_purpose=\"generate\"}) / clamp_min(sum(rag_llm_request_latency_ms_count{rag_llm_purpose=\"generate\"}), 1)",
          "legendFormat": "generate_answer",
          "refId": "A",
          "instant": true,
          "range": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_llm_request_latency_ms_sum{rag_llm_purpose=\"keyword_extract\"}) / clamp_min(sum(rag_llm_request_latency_ms_count{rag_llm_purpose=\"keyword_extract\"}), 1)",
          "legendFormat": "extract_keywords",
          "refId": "B",
          "instant": true,
          "range": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_embedding_latency_ms_sum) / clamp_min(sum(rag_embedding_latency_ms_count), 1)",
          "legendFormat": "embed_query",
          "refId": "C",
          "instant": true,
          "range": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_reranker_latency_ms_sum) / clamp_min(sum(rag_reranker_latency_ms_count), 1)",
          "legendFormat": "hybrid_rank",
          "refId": "D",
          "instant": true,
          "range": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_retrieval_vector_search_latency_ms_sum) / clamp_min(sum(rag_retrieval_vector_search_latency_ms_count), 1)",
          "legendFormat": "search_vectors",
          "refId": "E",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 7,
      "title": "Chat Request Volume",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Cumulative chat requests over time. Steps up with each new chat.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_requests_chat_total)",
          "legendFormat": "total chats",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 8,
      "title": "Document Ingestion — Embedding Latency (avg ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "OpenAI embedding API latency during document ingestion. High values = API slowdown or large batches.",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rag_embedding_latency_ms_sum{rag_call_site=\"chunk_batch\"}) / clamp_min(sum(rag_embedding_latency_ms_count{rag_call_site=\"chunk_batch\"}), 1)",
          "legendFormat": "avg embedding latency (ingestion)",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ]
    }
  ]
}
