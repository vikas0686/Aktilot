OPENAI_API_KEY=sk-...

# PostgreSQL (use @localhost for local dev, @postgres for Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docai

# Storage directories
UPLOAD_DIR=uploads
CHROMA_DIR=chroma_data
CONTEXT_DIR=context

# Models (optional — these are the defaults)
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
