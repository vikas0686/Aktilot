# ── Required ──────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# Used by docker-compose. Change @postgres to @localhost for local dev.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/docai

# ── Storage (optional — these are the defaults) ───────────────────────────────
UPLOAD_DIR=uploads
CHROMA_DIR=chroma_data
CONTEXT_DIR=context

# ── Providers and Models (optional — these are the defaults) ────────────────────────────────
LLM_PROVIDER=openai
CHAT_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ── Observability (optional — these are the defaults) ─────────────────────────
# OTLP gRPC endpoint for the OpenTelemetry Collector.
# In docker-compose this is set to http://otel-collector:4317 automatically.
OTEL_ENDPOINT=http://localhost:4317
ENVIRONMENT=development
APP_VERSION=0.1.0
