# ── Required ──────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# Used by docker-compose. Change @postgres to @localhost for local dev.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/docai

# ── Storage (optional — these are the defaults) ───────────────────────────────
UPLOAD_DIR=uploads
CHROMA_DIR=chroma_data
CONTEXT_DIR=context

# ── Models (optional — these are the defaults) ────────────────────────────────
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
